{
  "name": "weather-report-dashboard",
  "version": "1.0.0",
  "description": "LLM Session Diagnostic Dashboard - Weather Report Visualization",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "Jinx",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "papaparse": "^5.4.1"
  },
  "build": {
    "appId": "com.jinx.weather-report-dashboard",
    "productName": "Weather Report Dashboard",
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python/",
        "to": "python/",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"],
      "signAndEditExecutable": false
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
